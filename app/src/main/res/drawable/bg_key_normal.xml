<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Shadow (Bottom) with insets for gaps -->
    <item android:left="3dp" android:right="3dp" android:top="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="@color/key_shadow" />
        </shape>
    </item>
    <!-- Foreground Key -->
    <item android:left="3dp" android:right="3dp" android:top="4dp" android:bottom="6dp">
        <shape android:shape="rectangle">
            <corners android:radius="6dp" />
            <solid android:color="@color/key_bg_normal" />
        </shape>
    </item>
</layer-list>
